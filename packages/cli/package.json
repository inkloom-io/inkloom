{
  "name": "@inkloom/cli",
  "version": "0.2.2",
  "description": "InkLoom CLI — manage documentation sites from the command line",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inkloom-io/inkloom.git",
    "directory": "core/packages/cli"
  },
  "homepage": "https://docs.inkloom.io/cli",
  "bugs": {
    "url": "https://github.com/inkloom-io/inkloom/issues"
  },
  "keywords": [
    "inkloom",
    "cli",
    "documentation",
    "docs",
    "mdx",
    "deploy",
    "cloudflare-pages"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "bin": {
    "inkloom": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --import tsx --test tests/*.test.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "convex": "^1.14.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.0.0",
    "prompts": "^2.4.2",
    "yaml": "^2.8.2",
    "@sentry/node": "^9.0.0"
  },
  "devDependencies": {
    "@inkloom/mdx-parser": "workspace:*",
    "@inkloom/migration": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "create-inkloom": "workspace:*",
    "tsx": "^4.19.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
