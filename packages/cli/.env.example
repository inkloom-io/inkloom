# InkLoom CLI Configuration (end-user runtime config)
# These are set by END USERS of the published CLI, not by developers.
# They can also be set via ~/.inkloom/config.json or CLI flags.
# Environment variables take priority over the config file.
#
# NOTE: These are NOT part of the root .env.local — they are for users
# who install @inkloom/cli from npm, not for monorepo development.

# Authentication token (from `inkloom login` or dashboard API keys)
INKLOOM_TOKEN=

# Default organization ID
INKLOOM_ORG_ID=

# API base URL (defaults to https://inkloom.io)
# INKLOOM_API_URL=http://localhost:3000

# OpenRouter API key (required for `inkloom docs generate`)
OPENROUTER_API_KEY=
# INKLOOM_OPENROUTER_KEY=                   # Alias — OPENROUTER_API_KEY takes priority
