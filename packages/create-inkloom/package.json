{
  "name": "create-inkloom",
  "version": "0.1.0",
  "description": "Create a new InkLoom documentation site",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inkloom/inkloom.git",
    "directory": "packages/create-inkloom"
  },
  "homepage": "https://docs.inkloom.io/cli",
  "keywords": [
    "inkloom",
    "create",
    "documentation",
    "docs",
    "scaffolding",
    "starter"
  ],
  "type": "module",
  "bin": {
    "create-inkloom": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts",
    "dev": "tsup src/cli.ts src/index.ts --format esm --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.0.0",
    "prompts": "^2.4.2"
  },
  "publishConfig": { "access": "public", "registry": "https://registry.npmjs.org/" },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "minisearch": "^7.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.22.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
