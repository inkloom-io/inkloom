{
  "name": "@inkloom/mdx-parser",
  "version": "0.2.0",
  "description": "MDX to BlockNote and BlockNote to MDX conversion",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/inkloom-io/inkloom.git",
    "directory": "core/packages/mdx-parser"
  },
  "homepage": "https://github.com/inkloom-io/inkloom/tree/main/core/packages/mdx-parser",
  "bugs": {
    "url": "https://github.com/inkloom-io/inkloom/issues"
  },
  "keywords": [
    "mdx",
    "blocknote",
    "markdown",
    "parser",
    "converter",
    "editor",
    "inkloom"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  }
}
