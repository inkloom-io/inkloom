# =============================================================================
# Core Web App — Environment Variables
# =============================================================================
#
# For MONOREPO development: Do NOT create .env.local here.
# Instead, use the root .env.local — `pnpm run setup` symlinks it automatically.
# See the root .env.example for all available variables.
#
# For STANDALONE core development (outside the monorepo):
# Copy this file to .env.local and fill in the values.
# =============================================================================

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=

# Convex
NEXT_PUBLIC_CONVEX_URL=

# App URL (used for build output, sitemap generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Published docs domain (vanity subdomains like my-project.inkloom.dev)
NEXT_PUBLIC_DOCS_DOMAIN=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@inkloom.io
