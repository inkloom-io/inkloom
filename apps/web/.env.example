# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=

# Convex
NEXT_PUBLIC_CONVEX_URL=

# App URL (used for build output, sitemap generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Published docs domain (vanity subdomains like my-project.inkloom.dev)
NEXT_PUBLIC_DOCS_DOMAIN=

# PostHog Analytics (platform only)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=

# Rate Limiting — Upstash Redis (required for production / serverless)
# In-memory fallback works for single-instance dev but does NOT persist across
# serverless invocations. Set these for production deployments.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin Dashboard — comma-separated list of admin email addresses
ADMIN_EMAILS=
