# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=

# Convex
NEXT_PUBLIC_CONVEX_URL=

# App URL (used for build output, sitemap generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Published docs domain (vanity subdomains like my-project.inkloom.dev)
NEXT_PUBLIC_DOCS_DOMAIN=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@inkloom.io
