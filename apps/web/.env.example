# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=

# Convex
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=                # Convex HTTP actions endpoint (e.g., https://your-deployment.convex.site)
# CONVEX_DEPLOY_KEY=                        # CI/CD only — not needed for local dev

# WorkOS
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:3000/callback
WORKOS_COOKIE_PASSWORD=
# WORKOS_COOKIE_NAME=wos-session            # Optional — defaults to "wos-session"

# Cloudflare Pages (for deployments)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=inkloom-assets
R2_PUBLIC_URL=

# API Proxy (Cloudflare Worker for "Try It" playground CORS proxy)
NEXT_PUBLIC_API_PROXY_URL=

# Real-time Collaboration (PartyKit)
NEXT_PUBLIC_PARTYKIT_HOST=           # PartyKit server URL (e.g., inkloom-collab.yourname.partykit.dev)
COLLABORATION_JWT_SECRET=            # Shared secret for JWT signing (32+ random characters)
INTERNAL_API_SECRET=                 # Secret for PartyKit -> Convex sync webhook

# Custom Domains (Cloudflare for SaaS)
NEXT_PUBLIC_PLATFORM_DOMAIN=            # e.g., inklook.io — vanity subdomains: {slug}.inklook.io
CLOUDFLARE_ZONE_ID=                     # Zone ID for the platform domain (Custom Hostnames API)
CLOUDFLARE_KV_NAMESPACE_ID=             # KV namespace for custom domain → cfSlug mappings

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ENV=dev                           # "dev" or "production" — determines which stripe-ids.{env}.json to load
                                         # Price IDs are managed via config: see lib/stripe-config.ts
                                         # Run "pnpm stripe:setup" to create Stripe products/prices
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=      # pk_test_... or pk_live_... (client-side embedded checkout)

# Upstash Redis (API rate limiting — optional, gracefully skipped if not set)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App URL (used for Stripe redirects, SSO callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Github App (for OAuth and repo access)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=                     # Base64-encoded PEM private key
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_APP_URL=                 # e.g., https://github.com/apps/your-app/installations/new
GITHUB_WEBHOOK_SECRET=                      # Secret for verifying GitHub webhook payloads

# OpenRouter (LLM — required for AI doc generation features)
OPENROUTER_API_KEY=

# Testing (do NOT enable in production)
# TEST_AUTH_BYPASS=true                     # Bypasses WorkOS auth for Playwright E2E tests
# NEXT_PUBLIC_TEST_AUTH_BYPASS=true         # Bypasses client-side feature gates for E2E tests
